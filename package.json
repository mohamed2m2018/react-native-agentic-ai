{
  "name": "@mobileai/react-native",
  "version": "0.9.18",
  "description": "Build autonomous AI agents for React Native and Expo apps. Provides AI-native UI traversal, tool calling, and structured reasoning.",
  "main": "./lib/module/index.js",
  "types": "./lib/typescript/src/index.d.ts",
  "exports": {
    ".": {
      "types": "./lib/typescript/src/index.d.ts",
      "default": "./lib/module/index.js"
    },
    "./withAppIntents": {
      "types": "./lib/typescript/src/plugin/withAppIntents.d.ts",
      "default": "./lib/module/plugin/withAppIntents.js"
    },
    "./generate-map": "./generate-map.js",
    "./package.json": "./package.json"
  },
  "bin": {
    "react-native-ai-agent": "./bin/generate-map.cjs"
  },
  "files": [
    "lib",
    "bin",
    "generate-map.js",
    "android",
    "ios",
    "cpp",
    "*.podspec",
    "react-native.config.js",
    "!ios/build",
    "!android/build",
    "!android/gradle",
    "!android/gradlew",
    "!android/gradlew.bat",
    "!android/local.properties",
    "!**/__tests__",
    "!**/__fixtures__",
    "!**/__mocks__",
    "!lib/**/*.map",
    "!**/.*",
    "!mcp-server"
  ],
  "scripts": {
    "example": "yarn workspace @mobileai/react-native-example",
    "clean": "del-cli lib",
    "prepare": "bob build && rm -rf lib/module/cli lib/typescript/src/cli",
    "typecheck": "tsc -p tsconfig.build.json",
    "lint": "eslint \"**/*.{js,ts,tsx}\"",
    "test": "jest",
    "test:coverage": "jest --coverage",
    "publish:dual": "bash scripts/publish-dual.sh",
    "publish:dual:dry": "bash scripts/publish-dual.sh --dry-run",
    "generate-map": "ts-node src/cli/generate-map.ts"
  },
  "keywords": [
    "react-native",
    "expo",
    "ai",
    "ai-agent",
    "agentic-ai",
    "llm",
    "agent",
    "autonomous-agent",
    "gemini",
    "voice-ai",
    "voice-agent",
    "mcp",
    "model-context-protocol",
    "ai-testing",
    "mobile-ai",
    "ui-automation",
    "react-native-ai",
    "ai-assistant",
    "knowledge-base",
    "ai-sdk",
    "natural-language",
    "screen-reader",
    "accessibility",
    "human-in-the-loop"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/MobileAIAgent/react-native.git"
  },
  "author": "Mohamed Salah <mohamed2m2018@gmail.com> (https://example.com)",
  "license": "SEE LICENSE IN LICENSE",
  "bugs": {
    "url": "https://github.com/MobileAIAgent/react-native/issues"
  },
  "homepage": "https://github.com/MobileAIAgent/react-native#readme",
  "publishConfig": {
    "registry": "https://registry.npmjs.org/"
  },
  "devDependencies": {
    "@babel/parser": "^7.29.2",
    "@babel/traverse": "^7.29.0",
    "@babel/types": "^7.29.0",
    "@eslint/compat": "^1.3.2",
    "@eslint/eslintrc": "^3.3.1",
    "@eslint/js": "^9.35.0",
    "@react-native/babel-preset": "0.83.0",
    "@react-native/eslint-config": "0.83.0",
    "@testing-library/react-native": "^13.3.3",
    "@types/jest": "^29.5.14",
    "@types/react": "^19.1.12",
    "@types/react-native": "^0.72.8",
    "del-cli": "^6.0.0",
    "dotenv": "^17.3.1",
    "eslint": "^9.35.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.4",
    "jest": "^29.7.0",
    "prettier": "^3.5.0",
    "react": "19.2.0",
    "react-native": "0.83.2",
    "react-native-builder-bob": "^0.40.18",
    "react-test-renderer": "^19.2.0",
    "turbo": "^2.5.6",
    "typescript": "^5.9.2",
    "@google/genai": "^1.0.0",
    "react-native-audio-api": "*"
  },
  "peerDependencies": {
    "@google/genai": "*",
    "@react-native-async-storage/async-storage": "*",
    "expo-speech-recognition": "*",
    "react": "*",
    "react-native": "*",
    "react-native-audio-api": "*",
    "react-native-screens": "*",
    "react-native-view-shot": "*"
  },
  "peerDependenciesMeta": {
    "@google/genai": {
      "optional": true
    },
    "@react-native-async-storage/async-storage": {
      "optional": true
    },
    "react-native-audio-api": {
      "optional": true
    },
    "react-native-screens": {
      "optional": true
    },
    "react-native-view-shot": {
      "optional": true
    },
    "expo-speech-recognition": {
      "optional": true
    }
  },
  "codegenConfig": {
    "name": "RNMobileAIOverlaySpec",
    "type": "components",
    "jsSrcsDir": "src/specs",
    "android": {
      "javaPackageName": "com.mobileai.overlay"
    }
  },
  "workspaces": [
    "example-react-navigation"
  ],
  "react-native-builder-bob": {
    "source": "src",
    "output": "lib",
    "targets": [
      [
        "module",
        {
          "esm": true
        }
      ],
      [
        "typescript",
        {
          "project": "tsconfig.build.json"
        }
      ]
    ]
  },
  "prettier": {
    "quoteProps": "consistent",
    "singleQuote": true,
    "tabWidth": 2,
    "trailingComma": "es5",
    "useTabs": false
  },
  "jest": {
    "preset": "react-native",
    "setupFilesAfterEnv": [
      "<rootDir>/src/__tests__/setup.ts"
    ],
    "testMatch": [
      "**/?(*.)+(spec|test).[jt]s?(x)"
    ],
    "modulePathIgnorePatterns": [
      "<rootDir>/example-react-navigation/node_modules",
      "<rootDir>/lib/"
    ],
    "collectCoverageFrom": [
      "src/**/*.{ts,tsx}",
      "!src/**/*.d.ts",
      "!src/__tests__/**",
      "!src/index.ts"
    ]
  },
  "create-react-native-library": {
    "type": "library",
    "languages": "js",
    "tools": [
      "eslint",
      "jest"
    ],
    "version": "0.57.2"
  }
}
