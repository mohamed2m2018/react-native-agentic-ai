{
  "name": "react-native-agentic-ai",
  "version": "0.5.0",
  "description": "Build autonomous AI agents for React Native and Expo apps. Provides AI-native UI traversal, tool calling, and structured reasoning.",
  "main": "./lib/module/index.js",
  "source": "./src/index.ts",
  "types": "./lib/typescript/src/index.d.ts",
  "exports": {
    ".": {
      "source": "./src/index.ts",
      "types": "./lib/typescript/src/index.d.ts",
      "default": "./lib/module/index.js"
    },
    "./package.json": "./package.json"
  },
  "files": [
    "src",
    "lib",
    "android",
    "ios",
    "cpp",
    "*.podspec",
    "react-native.config.js",
    "!ios/build",
    "!android/build",
    "!android/gradle",
    "!android/gradlew",
    "!android/gradlew.bat",
    "!android/local.properties",
    "!**/__tests__",
    "!**/__fixtures__",
    "!**/__mocks__",
    "!**/.*",
    "!mcp-server"
  ],
  "scripts": {
    "example": "yarn workspace @mobileai/react-native-example",
    "clean": "del-cli lib",
    "prepare": "bob build",
    "typecheck": "tsc",
    "lint": "eslint \"**/*.{js,ts,tsx}\"",
    "test": "jest",
    "publish:dual": "bash scripts/publish-dual.sh",
    "publish:dual:dry": "bash scripts/publish-dual.sh --dry-run"
  },
  "keywords": [
    "react-native",
    "expo",
    "ai",
    "llm",
    "agent",
    "autonomous-agent",
    "gemini",
    "openai",
    "artificial-intelligence",
    "mobile-ai",
    "ui-automation",
    "react native ai agent"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/mohamed2m2018/mobileai-react-native.git"
  },
  "author": "Mohamed Salah <mohamedsalah@example.com> (https://example.com)",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/mohamed2m2018/mobileai-react-native/issues"
  },
  "homepage": "https://github.com/mohamed2m2018/mobileai-react-native#readme",
  "publishConfig": {
    "registry": "https://registry.npmjs.org/"
  },
  "devDependencies": {
    "@eslint/compat": "^1.3.2",
    "@eslint/eslintrc": "^3.3.1",
    "@eslint/js": "^9.35.0",
    "@react-native/babel-preset": "0.83.0",
    "@react-native/eslint-config": "0.83.0",
    "@types/jest": "^29.5.14",
    "@types/react": "^19.1.12",
    "@types/react-native": "^0.72.8",
    "del-cli": "^6.0.0",
    "eslint": "^9.35.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.4",
    "jest": "^29.7.0",
    "prettier": "^3.5.0",
    "react": "19.2.0",
    "react-native": "0.83.2",
    "react-native-builder-bob": "^0.40.18",
    "turbo": "^2.5.6",
    "typescript": "^5.9.2"
  },
  "dependencies": {
    "@google/genai": "^1.0.0",
    "react-native-audio-api": "^0.11.7"
  },
  "peerDependencies": {
    "react": "*",
    "react-native": "*",
    "react-native-audio-api": "*",
    "react-native-view-shot": "*",
    "expo-speech-recognition": "*"
  },
  "peerDependenciesMeta": {
    "react-native-audio-api": {
      "optional": true
    },
    "react-native-view-shot": {
      "optional": true
    },
    "expo-speech-recognition": {
      "optional": true
    }
  },
  "workspaces": [
    "example"
  ],
  "react-native-builder-bob": {
    "source": "src",
    "output": "lib",
    "targets": [
      [
        "module",
        {
          "esm": true
        }
      ],
      [
        "typescript",
        {
          "project": "tsconfig.build.json"
        }
      ]
    ]
  },
  "prettier": {
    "quoteProps": "consistent",
    "singleQuote": true,
    "tabWidth": 2,
    "trailingComma": "es5",
    "useTabs": false
  },
  "jest": {
    "preset": "react-native",
    "modulePathIgnorePatterns": [
      "<rootDir>/example/node_modules",
      "<rootDir>/lib/",
      "<rootDir>/rntl-reference"
    ]
  },
  "create-react-native-library": {
    "type": "library",
    "languages": "js",
    "tools": [
      "eslint",
      "jest"
    ],
    "version": "0.57.2"
  }
}
